<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Event Actions</h1>
    <p class="mt-1 text-sm text-gray-500">Repeat actions that compose a text file from your guests and deliver it to a webhook or email.</p>
  </div>
  {% if newHref != blank %}<a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700"
     title="New action" aria-label="New action" href="{{ newHref }}">
    <span>New action</span>
  </a>{% endif %}
</div>
{% if flash != blank %}<div class="bg-emerald-50 text-emerald-700 border border-gray-200 rounded-lg px-4 py-2 text-sm mb-4">{{ flash | t }}</div>{% endif %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guests</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Repeat</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Delivery</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Last run</th>
      <th class="px-6 py-3"></th>
    </tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for action in actions %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700 align-top">
            <a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ action.href }}">{{ action.name }}</a>
            <div class="mt-1">{% if action.enabled %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">Enabled</span>{% else %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Disabled</span>{% endif %}</div>
          </td>
          <td class="px-6 py-3 text-sm text-gray-700 align-top">{{ action.audience }}</td>
          <td class="px-6 py-3 text-sm text-gray-700 align-top">{{ action.repeat }}
            {% if action.nextRunAt != blank %}<div class="text-xs text-gray-400">Next: {{ action.nextRunAt | date: "%Y-%m-%d %H:%M" }} UTC</div>{% endif %}
          </td>
          <td class="px-6 py-3 text-sm text-gray-700 align-top">{{ action.delivery }}</td>
          <td class="px-6 py-3 text-sm text-gray-700 align-top">
            {% if action.lastRunAt != blank %}
              {% if action.lastRunOk %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">ok</span>{% else %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-red-50 text-red-700">error</span>{% endif %}
              <div class="text-xs text-gray-400">{{ action.lastRunAt | date: "%Y-%m-%d %H:%M" }} UTC</div>
            {% else %}<span class="text-xs text-gray-400">Never</span>{% endif %}
          </td>
          <td class="px-6 py-3 text-right text-sm align-top">
            <div class="flex items-center justify-end gap-2 flex-wrap">
              {% if canRun %}<form method="post" action="{{ action.runAction }}" class="inline"><button class="border-0 bg-transparent p-0 text-xs font-semibold text-indigo-600 cursor-pointer hover:text-indigo-800" type="submit">Run now</button></form>{% endif %}
              {% if canEdit %}<form method="post" action="{{ action.toggleAction }}" class="inline"><button class="border-0 bg-transparent p-0 text-xs font-semibold text-gray-500 cursor-pointer hover:text-indigo-700" type="submit">{% if action.enabled %}Disable{% else %}Enable{% endif %}</button></form>
              <form method="post" action="{{ action.deleteAction }}" class="inline" data-confirm="Delete this action?"><button class="border-0 bg-transparent p-0 text-xs font-semibold text-red-600 cursor-pointer" type="submit">Delete</button></form>{% endif %}
            </div>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="6" class="px-6 py-10 text-center text-sm text-gray-400">No actions yet. Create one to start composing and delivering guest files.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
